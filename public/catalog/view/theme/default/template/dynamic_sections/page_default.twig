{{ header }}
<div id="dynamic-page" class="container">
  <ul class="breadcrumb">
    {% for breadcrumb in breadcrumbs %}
    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
    {% endfor %}
  </ul>
  <div class="row">{{ column_left }}
    <div id="content" class="col-sm-9">
      <h1>{{ heading_title }}</h1>
      {% if image %}
      <div class="mb-3"><img src="{{ image }}" alt="{{ heading_title }}" class="img-fluid" /></div>
      {% endif %}
      <div>{{ description }}</div>
      {% if fields %}
      <div class="table-responsive mt-3">
        <table class="table table-bordered">
          {% for code, value in fields %}
          <tr>
            <td style="width: 30%;"><strong>{{ code }}</strong></td>
            <td>{{ value }}</td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}
      {% if images %}
      <div class="row mt-3">
        {% for img in images %}
        <div class="col-sm-3"><img src="{{ img.image }}" class="img-fluid" /></div>
        {% endfor %}
      </div>
      {% endif %}
      {% if tags %}
      <p class="mt-3">{{ text_tags }}
        {% for tag in tags %}
        <a href="{{ tag.href }}">{{ tag.tag }}</a>{% if not loop.last %}, {% endif %}
        {% endfor %}
      </p>
      {% endif %}
      {% if downloads %}
      <div class="mt-3">
        <h3>{{ text_download }}</h3>
        {% for download in downloads %}
        <div><a href="{{ download.href }}"><i class="bi bi-download"></i> {{ download.name }}</a></div>
        {% endfor %}
      </div>
      {% endif %}
      {% if relateds %}
      <div class="mt-4">
        <h3>{{ text_related }}</h3>
        <div class="row">
          {% for related in relateds %}
          <div class="col-sm-4 mb-3">
            <div class="card"><div class="card-body"><a href="{{ related.href }}">{{ related.name }}</a></div></div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}
      {% if related_products %}
      <div class="mt-4">
        <h3>{{ text_related_product }}</h3>
        <div class="row">
          {% for product in related_products %}
          <div class="col-sm-4 mb-3">
            <div class="card"><div class="card-body"><a href="{{ product.href }}">{{ product.name }}</a></div></div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}
      {% if review_status %}
      <div class="mt-4">
        <div class="rating">
          <p>{{ reviews }}</p>
        </div>
        <div id="review"></div>
        <h3>{{ text_write }}</h3>
        {% if not customer_name %}
        {{ text_login }}
        {% else %}
        <form id="form-review">
          <div class="form-group required">
            <label for="input-name">{{ entry_name }}</label>
            <input type="text" name="name" value="{{ customer_name }}" id="input-name" class="form-control" />
          </div>
          <div class="form-group required">
            <label for="input-review">{{ entry_review }}</label>
            <textarea name="text" rows="5" id="input-review" class="form-control"></textarea>
            <div class="form-text">{{ text_note }}</div>
          </div>
          <div class="form-group required">
            <label>{{ entry_rating }}</label>
            <div>
              <label><input type="radio" name="rating" value="1" /> 1</label>
              <label><input type="radio" name="rating" value="2" /> 2</label>
              <label><input type="radio" name="rating" value="3" /> 3</label>
              <label><input type="radio" name="rating" value="4" /> 4</label>
              <label><input type="radio" name="rating" value="5" /> 5</label>
            </div>
          </div>
          <button type="button" id="button-review" class="btn btn-primary">{{ button_continue }}</button>
        </form>
        {% endif %}
      </div>
      {% endif %}
      {{ content_bottom }}
    </div>
    {{ column_right }}
  </div>
</div>
{% if review_status and customer_name %}
<script>
$('#review').load('{{ review }}');

$('#button-review').on('click', function() {
  $.ajax({
    url: '{{ write_review }}',
    type: 'post',
    dataType: 'json',
    data: $('#form-review input, #form-review textarea'),
    success: function(json) {
      $('.alert-dismissible').remove();

      if (json['error']) {
        $('#review').after('<div class="alert alert-danger alert-dismissible">' + json['error'] + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
      }

      if (json['success']) {
        $('#review').after('<div class="alert alert-success alert-dismissible">' + json['success'] + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');

        $('input[name=\'name\']').val('');
        $('textarea[name=\'text\']').val('');
        $('input[name=\'rating\']:checked').prop('checked', false);

        $('#review').load('{{ review }}');
      }
    }
  });
});
</script>
{% endif %}
{{ footer }}
