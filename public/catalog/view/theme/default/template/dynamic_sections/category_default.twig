{{ header }}
<div id="dynamic-category" class="container">
  <ul class="breadcrumb">
    {% for breadcrumb in breadcrumbs %}
    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
    {% endfor %}
  </ul>
  <div class="row">{{ column_left }}
    <div id="content" class="col-sm-9">
      <h1>{{ heading_title }}</h1>
      {% if image %}
      <div class="mb-3"><img src="{{ image }}" alt="{{ heading_title }}" class="img-fluid" /></div>
      {% endif %}
      {% if description %}
      <div class="mb-3">{{ description }}</div>
      {% endif %}
      {% if categories %}
      <div class="row mb-3">
        {% for category in categories %}
        <div class="col-sm-4 mb-2">
          <a href="{{ category.href }}">{{ category.name }}</a>
        </div>
        {% endfor %}
      </div>
      {% endif %}
      {% if pages %}
      <div class="row">
        <div class="col-md-4">
          {% for page in pages %}
          <div class="mb-4">
            {% if page.image %}
            <div><a href="{{ page.href }}"><img src="{{ page.image }}" alt="{{ page.name }}" class="img-fluid" /></a></div>
            {% endif %}
            <h4><a href="{{ page.href }}">{{ page.name }}</a></h4>
            <p>{{ page.description }}</p>
            <small>{{ page.date_added }} | {{ page.viewed }} {{ text_views }}</small>
          </div>
          {% endfor %}
        </div>
      </div>
      <div class="row">
        <div class="col-sm-6 text-left">{{ pagination }}</div>
        <div class="col-sm-6 text-right">{{ results }}</div>
      </div>
      {% else %}
      <p>{{ text_empty }}</p>
      {% endif %}
      {{ content_bottom }}
    </div>
    {{ column_right }}
  </div>
</div>
{{ footer }}
