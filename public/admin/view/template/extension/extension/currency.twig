{{ promotion }}
<fieldset>
  <h6>{{ heading_title }}</h6>
  {% if error_warning %}
    <div role="alert" class="alert alert-danger alert-dismissible"><i class="bi bi-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  {% endif %}
  {% if success %}
    <div role="alert" class="alert alert-success alert-dismissible"><i class="bi bi-check-circle"></i> {{ success }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  {% endif %}
  <div role="alert" class="alert alert-info"><i class="bi bi-info-circle"></i> {{ text_layout }}</div>
  {% if hiden is not empty %}
    <div role="alert" class="alert alert-info"><i class="bi bi-check-circle"></i> {{ text_hide_modules }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  {% endif %}
  <div class="table-responsive">
    <table class="table table-bordered table-hover">
      <thead>
      <tr>
        <td class="text-left">{{ column_name }}</td>
        <td class="text-left">{{ column_status }}</td>
        <td class="text-right text-nowrap">{{ column_action }}</td>
      </tr>
      </thead>
      <tbody>

      {% if extensions %}
        {% for extension in extensions %}
          <tr>
            <td><b>{{ extension.name }}</b></td>
            <td>{{ extension.status }}</td>
            <td class="text-right text-nowrap">{% if extension.installed %}
                {% if extension.module %} <a href="{{ extension.edit }}" data-bs-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="bi bi-plus-circle"></i></a> {% else %} <a href="{{ extension.edit }}" data-bs-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary"><i class="bi bi-pencil-square"></i></a> {% endif %}
              {% else %}
                <button type="button" class="btn btn-primary" disabled="disabled"><i class="bi bi-pencil-square"></i></button>
              {% endif %}
              {% if not extension.installed %}<a href="{{ extension.install }}" data-bs-toggle="tooltip" title="{{ button_install }}" class="btn btn-success"><i class="bi bi-plus-circle"></i></a> {% else %} <a href="{{ extension.uninstall }}" data-bs-toggle="tooltip" title="{{ button_uninstall }}" class="btn btn-danger"><i class="bi bi-dash-circle"></i></a>{% endif %}</td>
          </tr>
          {% for module in extension.module %}
            <tr>
              <td class="text-left">&nbsp;&nbsp;&nbsp;<i class="bi bi-folder-open"></i>&nbsp;&nbsp;&nbsp;{{ module.name }}</td>
              <td class="text-left">{{ module.status }}</td>
              <td class="text-right text-nowrap"><a href="{{ module.edit }}" data-bs-toggle="tooltip" title="{{ button_edit }}" class="btn btn-info"><i class="bi bi-pencil-square"></i></a> <a href="{{ module.delete }}" data-bs-toggle="tooltip" title="{{ button_delete }}" class="btn btn-warning"><i class="bi bi-trash"></i></a></td>
            </tr>
          {% endfor %}
        {% endfor %}
      {% else %}
        <tr>
          <td class="text-center" colspan="3">{{ text_no_results }}</td>
        </tr>
      {% endif %}
      </tbody>

    </table>
  </div>
</fieldset>