{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-module" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="bi bi-floppy"></i></button>
        <a href="{{ cancel }}" data-bs-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-secondary"><i class="bi bi-arrow-left"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div role="alert" class="alert alert-danger alert-dismissible"><i class="bi bi-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}
    <div class="card">
      <div class="card-header"><h3 class="card-title mb-0"><i class="bi bi-pencil-square"></i> {{ text_edit }}</h3></div>
      <div class="card-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-module" class="form-horizontal">
          {{ form({type: 'text', name: 'name', value: name, label: entry_name, placeholder: entry_name, id: 'input-name', error: error_name}) }}

          {{ form({type: 'select', name: 'section_id', value: section_id, label: entry_section, id: 'input-section', noselect: text_select, options: [sections|map(section => section.section_id), sections|map(section => section.name)], error: error_section}) }}

          {{ form({type: 'text', name: 'limit', value: limit, label: entry_limit, placeholder: entry_limit, id: 'input-limit'}) }}

          {{ form({type: 'text', name: 'width', value: width, label: entry_width, placeholder: entry_width, id: 'input-width', error: error_width}) }}

          {{ form({type: 'text', name: 'height', value: height, label: entry_height, placeholder: entry_height, id: 'input-height', error: error_height}) }}

          {{ form({type: 'select', name: 'status', value: status, label: entry_status, id: 'input-status', options: [[1, 0], [text_enabled, text_disabled]]}) }}
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
