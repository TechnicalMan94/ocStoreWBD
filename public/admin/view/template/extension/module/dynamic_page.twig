{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-module" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="bi bi-floppy"></i></button>
        <a href="{{ cancel }}" data-bs-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-secondary"><i class="bi bi-arrow-left"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div role="alert" class="alert alert-danger alert-dismissible"><i class="bi bi-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}
    <div class="card">
      <div class="card-header"><h3 class="card-title mb-0"><i class="bi bi-pencil-square"></i> {{ text_edit }}</h3></div>
      <div class="card-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-module" class="form-horizontal">
          <div class="form-group">
            <label class="col-sm-2 col-form-label" for="input-name">{{ entry_name }}</label>
            <div class="col-sm-10">
              <input type="text" name="name" value="{{ name }}" placeholder="{{ entry_name }}" id="input-name" class="form-control" />
              {% if error_name %}<div class="text-danger">{{ error_name }}</div>{% endif %}
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 col-form-label" for="input-section">{{ entry_section }}</label>
            <div class="col-sm-10">
              <select name="section_id" id="input-section" class="form-control">
                <option value="0">{{ text_select }}</option>
                {% for section in sections %}
                <option value="{{ section.section_id }}"{% if section.section_id == section_id %} selected="selected"{% endif %}>{{ section.name }}</option>
                {% endfor %}
              </select>
              {% if error_section %}<div class="text-danger">{{ error_section }}</div>{% endif %}
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 col-form-label" for="input-source-page"><span data-bs-toggle="tooltip" title="{{ help_source_page }}">{{ entry_source_page }}</span></label>
            <div class="col-sm-10">
              <input type="text" name="source_page_name" value="{{ source_page_name }}" placeholder="{{ text_none }}" id="input-source-page" class="form-control" />
              <input type="hidden" name="source_page_id" value="{{ source_page_id }}" />
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 col-form-label" for="input-limit">{{ entry_limit }}</label>
            <div class="col-sm-10"><input type="text" name="limit" value="{{ limit }}" placeholder="{{ entry_limit }}" id="input-limit" class="form-control" /></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 col-form-label" for="input-width">{{ entry_width }}</label>
            <div class="col-sm-10">
              <input type="text" name="width" value="{{ width }}" placeholder="{{ entry_width }}" id="input-width" class="form-control" />
              {% if error_width %}<div class="text-danger">{{ error_width }}</div>{% endif %}
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 col-form-label" for="input-height">{{ entry_height }}</label>
            <div class="col-sm-10">
              <input type="text" name="height" value="{{ height }}" placeholder="{{ entry_height }}" id="input-height" class="form-control" />
              {% if error_height %}<div class="text-danger">{{ error_height }}</div>{% endif %}
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 col-form-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="status" id="input-status" class="form-control">
                <option value="1"{% if status %} selected="selected"{% endif %}>{{ text_enabled }}</option>
                <option value="0"{% if not status %} selected="selected"{% endif %}>{{ text_disabled }}</option>
              </select>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
  <script>
$('input[name=\'source_page_name\']').autocomplete({
  source: function(request, response) {
    $.ajax({
      url: 'index.php?route=dynamic/page/autocomplete&user_token={{ user_token }}&section_id=' + $('#input-section').val() + '&filter_name=' + encodeURIComponent(request),
      dataType: 'json',
      success: function(json) {
        response($.map(json, function(item) {
          return { label: item['name'], value: item['page_id'] };
        }));
      }
    });
  },
  select: function(item) {
    $('input[name=\'source_page_name\']').val(item['label']);
    $('input[name=\'source_page_id\']').val(item['value']);
  }
});

$('input[name=\'source_page_name\']').on('input', function() {
  if (!$(this).val()) {
    $('input[name=\'source_page_id\']').val('0');
  }
});

$('#input-section').on('change', function() {
  $('input[name=\'source_page_name\']').val('');
  $('input[name=\'source_page_id\']').val('0');
});
</script>
</div>
{{ footer }}
