{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        <li><a href="{{ home }}">Home</a></li>
        <li><a href="{{ section_link }}">Разделы</a></li>
        <li>{{ heading_title }}</li>
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if errors %}
    <div class="alert alert-danger">
      {% for error in errors %}
      <p><i class="bi bi-exclamation-circle"></i> {{ error }}</p>
      {% endfor %}
    </div>
    {% endif %}

    {% if messages %}
    <div class="alert alert-info">
      {% for msg in messages %}
      <p><i class="bi bi-check-circle"></i> {{ msg }}</p>
      {% endfor %}
    </div>
    {% endif %}

    <div class="card">
      <div class="card-header"><i class="bi bi-database"></i> Миграция данных</div>
      <div class="card-body">
        <div class="alert alert-warning">
          <i class="bi bi-exclamation-triangle"></i> {{ text_confirm }}
        </div>
        <form action="{{ action }}" method="post">
          <button type="submit" class="btn btn-primary"><i class="bi bi-play"></i> {{ button_migrate }}</button>
        </form>
      </div>
    </div>

    <div class="card mt-4">
      <div class="card-header"><i class="bi bi-trash"></i> Очистка старых данных</div>
      <div class="card-body">
        <div class="alert alert-danger">
          <i class="bi bi-exclamation-triangle"></i> {{ text_delete_confirm }}
        </div>
        <a href="{{ delete_action }}" class="btn btn-danger" onclick="return confirm('Вы уверены? Это действие нельзя отменить.');"><i class="bi bi-trash"></i> {{ button_delete_old }}</a>
      </div>
    </div>
  </div>
</div>
{{ footer }}
