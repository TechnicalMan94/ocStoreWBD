{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="button" data-bs-toggle="tooltip" title="{{ button_filter }}" onclick="$('#filter-service').toggleClass('d-none d-md-block');" class="btn btn-light d-md-none"><i class="bi bi-funnel"></i></button>
        <a href="{{ add }}" data-bs-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i></a>
        <button type="submit" form="form-service" formaction="{{ copy }}" data-bs-toggle="tooltip" title="{{ button_copy }}" class="btn btn-light"><i class="bi bi-copy"></i></button>
        <button type="submit" form="form-service" formaction="{{ enabled }}" data-bs-toggle="tooltip" title="{{ button_enable }}" class="btn btn-light"><i class="bi bi-play-fill"></i></button>
		<button type="submit" form="form-service" formaction="{{ disabled }}" data-bs-toggle="tooltip" title="{{ button_disable }}" class="btn btn-light"><i class="bi bi-pause-fill"></i></button>
		<button type="button" form="form-service" formaction="{{ delete }}" data-bs-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-service').submit() : false;"><i class="bi bi-trash"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">{% if error_warning %}
    <div role="alert" class="alert alert-danger alert-dismissible"><i class="bi bi-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}
    {% if success %}
    <div role="alert" class="alert alert-success alert-dismissible"><i class="bi bi-check-circle"></i> {{ success }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}
    <div class="row">
      <div id="filter-service" class="col-md-3 order-md-2 col-sm-12 d-none d-md-block">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title mb-0"><i class="bi bi-funnel"></i> {{ text_filter }}</h3>
          </div>
          <div class="card-body">
            <div class="form-group">
              <label class="col-form-label" for="input-name">{{ entry_name }}</label>
			  <div class="input-group">
              <input type="text" name="filter_name" value="{{ filter_name }}" placeholder="{{ entry_name }}" id="input-name" class="form-control" />
			  <div class="input-group-btn">
                    <button type="button" id="button-clear-input-name" class="btn btn-light"><i class="bi bi-x-lg"></i></button>
			</div>
			</div>
			</div>  
            <div class="form-group">
              <label class="col-form-label" for="input-status">{{ entry_status }}</label>
              <select name="filter_status" id="input-status" class="form-control">
                <option value=""></option>
                  {% if filter_status == '1' %}
                <option value="1" selected="selected">{{ text_enabled }}</option>
                  {% else %}
                <option value="1">{{ text_enabled }}</option>
                  {% endif %}
                  {% if filter_status == '0' %}
				<option value="0" selected="selected">{{ text_disabled }}</option>
				  {% else %}
				<option value="0">{{ text_disabled }}</option>
                  {% endif %}
              </select>
            </div>
			<div class="form-group">
              <label class="col-form-label" for="input-noindex">{{ entry_noindex }}</label>
              <select name="filter_noindex" id="input-noindex" class="form-control">
                <option value=""></option>
                  {% if filter_noindex == '1' %}
                <option value="1" selected="selected">{{ text_enabled }}</option>
                  {% else %}
                <option value="1">{{ text_enabled }}</option>
                  {% endif %}
                  {% if filter_noindex == '0' %}
                <option value="0" selected="selected">{{ text_disabled }}</option>
                  {% else %}
                <option value="0">{{ text_disabled }}</option>
                  {% endif %}
              </select>
			</div>
            <div class="form-group text-right">
              <button type="button" id="button-filter" class="btn btn-light"><i class="bi bi-funnel"></i> {{ button_filter }}</button>
			  <button type="button" id="button-clear-filter" class="btn btn-light"><i class="bi bi-x-lg"></i><span class="d-sm-none d-md-inline"> {{ button_clear }}</span></button>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-9 order-md-1 col-sm-12">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title mb-0"><i class="bi bi-list-ul"></i> {{ text_list }}</h3>
          </div>
          <div class="card-body">
            <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-service">
              <div class="table-responsive">
                <table class="table table-bordered table-hover">
                  <thead>
                    <tr>
                      <td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" /></td>
                      <td class="text-center">{{ column_image }}</td>
                      <td class="text-left">{% if sort == 'pd.name' %} <a href="{{ sort_name }}" class="{{ order|lower }}">{{ column_name }}</a> {% else %} <a href="{{ sort_name }}">{{ column_name }}</a> {% endif %}</td>
                      <td class="text-left">{% if sort == 'p.status' %} <a href="{{ sort_status }}" class="{{ order|lower }}">{{ column_status }}</a> {% else %} <a href="{{ sort_status }}">{{ column_status }}</a> {% endif %}</td>
                      <td class="text-left">{% if sort == 'p.noindex' %} <a href="{{ sort_noindex }}" class="{{ order|lower }}">{{ column_noindex }}</a> {% else %} <a href="{{ sort_noindex }}">{{ column_noindex }}</a> {% endif %}</td>
					  <td class="text-right">{{ column_action }}</td>
                    </tr>
                  </thead>
                  <tbody>
                  
                  {% if services %}
                  {% for service in services %}
                  <tr>
                    <td class="text-center">{% if service.service_id in selected %}
                      <input type="checkbox" name="selected[]" value="{{ service.service_id }}" checked="checked" />
                      {% else %}
                      <input type="checkbox" name="selected[]" value="{{ service.service_id }}" />
                      {% endif %}</td>
                    <td class="text-center">{% if service.image %} <img src="{{ service.image }}" alt="{{ service.name }}" class="img-thumbnail" /> {% else %} <span class="img-thumbnail list"><i class="bi bi-camera fs-2"></i></span> {% endif %}</td>
                    <td class="text-left">{{ service.name }}</td>
                    <td class="text-left">{{ service.status }}</td>
					<td class="text-left">{{ service.noindex }}</td>
                    <td class="text-right">
						<a target="_blank" href="{{ service.href_shop }}" data-bs-toggle="tooltip" title="{{ button_shop }}" class="btn btn-success"><i class="bi bi-eye"></i></a>
						<a href="{{ service.edit }}" data-bs-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary"><i class="bi bi-pencil-square"></i></a>
					</td>
                  </tr>
                  {% endfor %}
                  {% else %}
                  <tr>
                    <td class="text-center" colspan="9">{{ text_no_results }}</td>
                  </tr>
                  {% endif %}
                    </tbody>
                  
                </table>
              </div>
            </form>
            <div class="row">
              <div class="col-sm-6 text-left">{{ pagination }}</div>
              <div class="col-sm-6 text-right">{{ results }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
$('#button-filter').on('click', function() {
	var url = '';

	var filter_name = $('input[name=\'filter_name\']').val();

	if (filter_name) {
		url += '&filter_name=' + encodeURIComponent(filter_name);
	}

	var filter_status = $('select[name=\'filter_status\']').val();

	if (filter_status !== '') {
		url += '&filter_status=' + encodeURIComponent(filter_status);
	}
	
	var filter_noindex = $('select[name=\'filter_noindex\']').val();
	
	if (filter_noindex !== '') {
		url += '&filter_noindex=' + encodeURIComponent(filter_noindex);
	}

	location = 'index.php?route=service/service&user_token={{ user_token }}' + url;
});
$('#button-clear-filter').on('click', function() {
	location = 'index.php?route=service/service&user_token={{ user_token }}';
});
</script> 
  <script>
// IE and Edge fix!
$('button[form=\'form-service\']').on('click', function(e) {
	$('#form-service').attr('action', $(this).attr('formaction'));
});
  
$('input[name=\'filter_name\']').autocomplete({
	'source': function(request, response) {
		$.ajax({
			url: 'index.php?route=service/service/autocomplete&user_token={{ user_token }}&filter_name=' +  encodeURIComponent(request),
			dataType: 'json',
			success: function(json) {
				response($.map(json, function(item) {
					return {
						label: item['name'],
						value: item['service_id']
					}
				}));
			}
		});
	},
	'select': function(item) {
		$('input[name=\'filter_name\']').val(item['label']);
	}
});
$('#button-clear-input-name').on('click',function(){
	$('input[name=\'filter_name\']').val('');
	$('#button-filter').trigger('click');
});
$('#filter-service').on('keydown', function(e) {
  if (e.keyCode == 13) {
    $('#button-filter').trigger('click')
  }
});
</script></div>
{{ footer }} 