{{ header }}
<div id="content">
  <div class="container-fluid"><br />
    <br />
    <div class="row">
      <div class="offset-sm-4 col-sm-4">
        <div class="card">
          <div class="card-header">
            <h1 class="card-title mb-0"><i class="bi bi-arrow-repeat"></i> {{ heading_title }}</h1>
          </div>
          <div class="card-body">
            {% if error_warning %}
            <div class="alert alert-danger alert-dismissible"><i class="bi bi-exclamation-circle"></i> {{ error_warning }}
              <button type="button" class="close" data-bs-dismiss="alert">&times;</button>
            </div>
            {% endif %}
            <form action="{{ action }}" method="post" enctype="multipart/form-data">
              <div class="form-group">
                <label for="input-email">{{ entry_email }}</label>
                <div class="input-group"><span class="input-group-text"><i class="bi bi-envelope"></i></span>
                  <input type="text" name="email" value="{{ email }}" placeholder="{{ entry_email }}" id="input-email" class="form-control" />
                </div>
              </div>
              <div class="text-right">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> {{ button_reset }}</button>
                <a href="{{ cancel }}" data-bs-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-light"><i class="bi bi-arrow-left"></i></a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{{ footer }}